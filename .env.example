# ─────────────────────────────────────────────────────────────
# Supabase / PostgreSQL
# En Supabase: Project Settings → Database → Connection string
#  - DATABASE_URL: usa "Transaction pooler" (puerto 6543) + ?pgbouncer=true
#  - DIRECT_URL:   usa "Direct connection" (puerto 5432) para migraciones
# ─────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# ─────────────────────────────────────────────────────────────
# NextAuth
# AUTH_SECRET: genera uno con `npx auth secret` o `openssl rand -base64 32`
# ─────────────────────────────────────────────────────────────
AUTH_SECRET="reemplaza-con-un-secreto-aleatorio"
AUTH_URL="http://localhost:3000"

# Google OAuth (opcional, para una fase futura)
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""

# ─────────────────────────────────────────────────────────────
# Endpoints de administración (/api/admin/*): actualizar resultados
# y avanzar el torneo. Genera uno con `openssl rand -hex 16`.
# ─────────────────────────────────────────────────────────────
ADMIN_SECRET="reemplaza-con-un-secreto-aleatorio"

# ─────────────────────────────────────────────────────────────
# Web Push (notificaciones). Opcional: sin estas claves, el centro
# in-app funciona y el push queda desactivado.
# Genera las claves con: npx web-push generate-vapid-keys
# NEXT_PUBLIC_VAPID_PUBLIC_KEY debe ser idéntica a VAPID_PUBLIC_KEY.
# ─────────────────────────────────────────────────────────────
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:tu-email@dominio.com"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""

# ─────────────────────────────────────────────────────────────
# API-Football (datos reales + en vivo del Mundial). Opcional:
# si no está, la app usa openfootball (calendario público, sin clave).
# Consíguela en https://dashboard.api-football.com
# ─────────────────────────────────────────────────────────────
API_FOOTBALL_KEY=""

# ─────────────────────────────────────────────────────────────
# Feature flags (se evalúan en build; cambiarlos requiere redeploy)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_FEATURE_MINI_LEAGUES="false"

# YouTube Data API v3 (vídeos de previa/resumen del canal @Replay en la
# página de partido). Crea una clave gratis en Google Cloud Console:
#  1. console.cloud.google.com → crea proyecto.
#  2. "APIs y servicios" → habilita "YouTube Data API v3".
#  3. "Credenciales" → "Crear credenciales" → "Clave de API". Pégala aquí.
# Sin esta clave, la previa/resumen simplemente no aparece (no rompe nada).
YOUTUBE_API_KEY=""
