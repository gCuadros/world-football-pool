generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  name                String?
  avatar              String?
  passwordHash        String?
  emailVerified       DateTime?
  image               String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  favoriteTeam        String?
  accounts           Account[]
  achievements       Achievement[]
  miniLeaguesCreated MiniLeague[]       @relation("MiniLeagueCreator")
  miniLeagueMembers  MiniLeagueMember[]
  predictions        Prediction[]
  sessions           Session[]
  notifications      Notification[]
  pushSubscriptions  PushSubscription[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Match {
  id          String       @id @default(cuid())
  matchNo     Int          @unique
  homeTeam    String
  awayTeam    String
  homeFlag    String?
  awayFlag    String?
  kickoffAt   DateTime
  stage       Stage
  group       String?
  stadium     String
  city        String?
  homeScore   Int?
  awayScore   Int?
  status      MatchStatus  @default(UPCOMING)
  liveMinute  Int?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  awayCrest   String?
  externalId  String?      @unique
  homeCrest   String?
  predictions Prediction[]

  @@index([kickoffAt])
  @@index([status])
  @@index([stage])
}

model Prediction {
  id          String     @id @default(cuid())
  userId      String
  matchId     String
  leagueId    String
  homeScore   Int
  awayScore   Int
  points      Int?
  submittedAt DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  match       Match      @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  league      MiniLeague @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@unique([userId, leagueId, matchId])
  @@index([matchId])
  @@index([userId])
  @@index([leagueId])
}

model MiniLeague {
  id          String             @id @default(cuid())
  name        String
  inviteCode  String             @unique
  createdById String
  createdAt   DateTime           @default(now())
  createdBy   User               @relation("MiniLeagueCreator", fields: [createdById], references: [id], onDelete: Cascade)
  members      MiniLeagueMember[]
  predictions  Prediction[]
  achievements Achievement[]
}

model MiniLeagueMember {
  id           String     @id @default(cuid())
  userId       String
  miniLeagueId String
  joinedAt     DateTime   @default(now())
  miniLeague   MiniLeague @relation(fields: [miniLeagueId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, miniLeagueId])
  @@index([miniLeagueId])
}

model Achievement {
  id         String          @id @default(cuid())
  userId     String
  leagueId   String
  type       AchievementType
  unlockedAt DateTime        @default(now())
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  league     MiniLeague      @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@unique([userId, leagueId, type])
  @@index([userId])
  @@index([leagueId])
}


enum Stage {
  GROUP_STAGE
  ROUND_OF_32
  ROUND_OF_16
  QUARTER_FINAL
  SEMI_FINAL
  THIRD_PLACE
  FINAL
}

enum MatchStatus {
  UPCOMING
  LIVE
  FINISHED
}

enum AchievementType {
  PERFECT_SCORE
  STREAK_3
  STREAK_5
  STREAK_10
  TOP_10
  TOP_3
  ALL_GROUP_STAGE
  CHAMPION_CALL
}

enum NotificationType {
  PREDICTION_REMINDER
  MATCH_RESULT
  LEAGUE_RANK
  LEAGUE_JOIN
  LIVE_GOAL
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  link      String?
  matchId   String?
  leagueId  String?
  readAt    DateTime?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
